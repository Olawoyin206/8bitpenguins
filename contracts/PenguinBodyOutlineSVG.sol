pragma solidity ^0.8.20;

import "./EightBitPenguinsRendererData.sol";

contract PenguinBodyOutlineSVG {
    string private constant OUTLINE_NONE = "";
    string private constant OUTLINE_CAP = "";
    string private constant OUTLINE_BEANIE = "";
    string private constant OUTLINE_SCARF = "";
    string private constant OUTLINE_HEADBAND = "";
    string private constant OUTLINE_CROWN_IMPERIAL = "";
    string private constant OUTLINE_CROWN_ELEGANT = "";
    string private constant OUTLINE_HALO = "";

    function render(uint256 packedTraits) external pure returns (string memory) {
        EightBitPenguinsRendererData.Palette memory p = EightBitPenguinsRendererData.paletteFromPacked(packedTraits);
        return imageTag(outlineForPalette(p));
    }

    function outlineForPalette(EightBitPenguinsRendererData.Palette memory) private pure returns (string memory) {
        return OUTLINE_NONE;
    }

    function imageTag(string memory pngBase64) private pure returns (string memory) {
        return string(
            abi.encodePacked(
                '<image x="0" y="0" width="256" height="256" preserveAspectRatio="none" image-rendering="pixelated" href="data:image/png;base64,',
                pngBase64,
                '"/>'
            )
        );
    }
}
