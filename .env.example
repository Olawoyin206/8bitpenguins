PINATA_JWT=your_pinata_jwt_here
# Optional legacy frontend var (not used by /api/ipfs-upload):
VITE_PINATA_JWT=
# Upload API allowlist (comma-separated full origins)
ALLOWED_ORIGINS=http://localhost:5173,https://8bitpenguins.xyz,https://www.8bitpenguins.xyz
# Optional hostname suffix allowlist (comma-separated), e.g. for preview deploys:
# ALLOWED_ORIGIN_SUFFIXES=vercel.app
ALLOWED_ORIGIN_SUFFIXES=
# Upload API limits/tuning
IPFS_UPLOAD_MAX_BYTES=8388608
IPFS_UPLOAD_RATE_WINDOW_MS=60000
IPFS_UPLOAD_RATE_MAX=20
IPFS_UPLOAD_TIMEOUT_MS=15000
LOCAL_GALLERY_PORT=8787
VITE_RPC_URL=https://ethereum-rpc.publicnode.com
# Optional: set true to enable multi-RPC fallback reads.
VITE_ENABLE_RPC_FALLBACKS=false
VITE_RPC_FALLBACK_URLS=https://eth.llamarpc.com,https://rpc.ankr.com/eth
VITE_CHAIN_ID_HEX=0x1
VITE_CHAIN_NAME=Ethereum Mainnet
VITE_BLOCK_EXPLORER_URL=https://etherscan.io
VITE_CONTRACT_ADDRESS=0xC15C47C75baAB1D22954DC5E814B520FdE809729
# Optional mint gate (when set, Mint page uses gate for phases + whitelist proofs)
VITE_MINT_GATE_ADDRESS=0xB01426C962926F1D1aE18fF0e784cE90a35a9717
CONTRACT_ADDRESS=0xC15C47C75baAB1D22954DC5E814B520FdE809729
# Frontend direct Apps Script URL (optional).
# If unset in production, frontend falls back to /api/google-script.
VITE_GOOGLE_SCRIPT_URL=
# Snapshot lock for /task and /play-to-wl pages.
# Set true now (post-snapshot), switch to false on mint day.
VITE_SNAPSHOT_LOCK_ENABLED=true
VITE_SNAPSHOT_LOCK_TITLE=Snapshot Taken
VITE_SNAPSHOT_LOCK_NOTE=Please wait for Mint Day.

ETH_MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com
# Optional testnet RPC (used only when targeting Sepolia scripts/network explicitly):
ETH_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ETHERSCAN_API_KEY=your_etherscan_key_here
PRIVATE_KEY=your_wallet_private_key_here

# Admin API security/config (required for /api/admin-session, /api/admin-data, /api/admin-maintenance)
GOOGLE_SCRIPT_URL=
ADMIN_SESSION_SECRET=replace_with_long_random_secret
ADMIN_CHAIN_ID=0x1
ADMIN_CONTRACT_ADDRESS=0xC15C47C75baAB1D22954DC5E814B520FdE809729
ADMIN_MINT_GATE_ADDRESS=0xB01426C962926F1D1aE18fF0e784cE90a35a9717
# Optional override (otherwise read from on-chain owner)
ADMIN_OWNER_ADDRESS=
# Durable nonce store (Upstash Redis REST)
ADMIN_NONCE_STORE_URL=
ADMIN_NONCE_STORE_TOKEN=
# Equivalent aliases supported by the API handlers:
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Off-chain whitelist proof (no large wallet list stored on-chain)
# Use signer key that matches on-chain `whitelistSigner`.
WHITELIST_SIGNER_PRIVATE_KEY=
# Optional explicit signer address used when deploying gate.
WHITELIST_SIGNER_ADDRESS=
# Mint gate contract address used by proof API signature binding.
WHITELIST_GATE_ADDRESS=0xB01426C962926F1D1aE18fF0e784cE90a35a9717
# Mint proceeds destination on gate mint.
MINT_GATE_PAYOUT_RECEIVER=
# Expiry (seconds) for generated mint proof signatures.
WHITELIST_PROOF_TTL_SECONDS=900
# Runtime whitelist snapshot file used by /api/whitelist-proof.
WHITELIST_SNAPSHOT_FILE=cache/whitelist-snapshot.json
# Snapshot read cache (ms) inside API.
WHITELIST_SNAPSHOT_CACHE_TTL_MS=60000
# Batch eligibility cache (ms) for all-phase checks.
WHITELIST_BATCH_CACHE_TTL_MS=120000
# Optional chain id override for signed payloads (defaults to snapshot chainId).
WHITELIST_CHAIN_ID=1
# Phase -> sheet URL map (phase IDs as keys). Each URL should point to a sheet tab (public/readable).
# Example:
# WHITELIST_PHASE_SHEETS={"0":"https://docs.google.com/spreadsheets/d/.../edit#gid=0","1":"https://docs.google.com/spreadsheets/d/.../edit#gid=12345"}
WHITELIST_PHASE_SHEETS=
# Optional single workbook URL. When set, API auto-matches phase names to sheet tabs.
WHITELIST_WORKBOOK_URL=

# JSONBin.io for shared gallery (free tier)
# 1. Go to https://jsonbin.io and create a free account
# 2. Create a new bin and get your API key (X-Access-Key)
# 3. Get your Bin ID from the bin URL
VITE_JSONBIN_KEY=your_jsonbin_access_key_here
VITE_JSONBIN_BIN_ID=your_jsonbin_bin_id_here
